{
  "name": "@withfrontmatter/solo-check",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "frontmatter-check": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "fm-skill.md",
    "README_AI.md",
    "prompts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --clean --external @withfrontmatter/core --external @withfrontmatter/solo-rules --external commander --external kleur",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@withfrontmatter/core": "^1.0.4",
    "@withfrontmatter/solo-rules": "^0.1.1",
    "commander": "^14.0.2",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
